   70          static void tcs3400_init(void) 
   71          {
   72   1          tcs3400_write_register(TCS3400_ENABLE, 0x00);
   73   1          // ЩшжУЛ§ЗжЪБМф
   74   1          tcs3400_write_register(TCS3400_ATIME, 0xFF);//1024 step
   75   1          // ЩшжУдівц
