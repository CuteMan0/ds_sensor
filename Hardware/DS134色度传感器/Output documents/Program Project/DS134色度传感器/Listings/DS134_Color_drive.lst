   94          static void tcs3400_read_color(tcs3400_data_t *dev) 
   95          {
   96   1          u8 status = 0;
   97   1          u8 buf[8] = {0};
   98   1          float rgb_sum = 0.0f;
   99   1          
  100   1          do{
  101   2          tcs3400_read_register(TCS3400_STATUS,&status);
  102   2          }
  103   1          while(!(status & 0x01));
  104   1          
  105   1          tcs3400_read_data(TCS3400_I2C_ADDR, TCS3400_CDATAL, buf, 8);
  106   1          
  107   1      //    dev->clear = (buf[1] << 8) | buf[0];
  108   1          dev->red   = (buf[3] << 8) | buf[2];
  109   1          dev->green = (buf[5] << 8) | buf[4];
  110   1          dev->blue  = (buf[7] << 8) | buf[6];
  111   1          rgb_sum = dev->red + dev->green + dev->blue;
  112   1          if(rgb_sum != 0.0f)
  113   1          {
  114   2              dev->red = dev->red / rgb_sum * 100.0f;
  115   2              dev->green = dev->green / rgb_sum * 100.0f;
  116   2              dev->blue = dev->blue / rgb_sum * 100.0f;
  117   2          }
  118   1      }
