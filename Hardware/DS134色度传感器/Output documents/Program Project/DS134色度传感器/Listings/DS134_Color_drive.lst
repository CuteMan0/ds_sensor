  120          static void tcs3400_write_register(u8 reg, u8 val)
  121          {
  122   1          soft_i2c_start();
  123   1          soft_i2c_write_byte(TCS3400_I2C_ADDR << 1);  // аДЕижЗ
  124   1          soft_i2c_write_byte(TCS3400_ENABLE | reg);
C251 COMPILER V5.60.0,  DS134_Color_drive                                                  19/05/26  11:10:49  PAGE 3   

  125   1          soft_i2c_write_byte(val);
  126   1          soft_i2c_stop();
  127   1      }
  128          
  129          static void tcs3400_read_register(u8 reg, u8 *val)
  130          {
  131   1          soft_i2c_start();
  132   1          soft_i2c_write_byte(TCS3400_I2C_ADDR << 1);  // аДЕижЗ
  133   1          soft_i2c_write_byte(reg);
  134   1          soft_i2c_start();                   // жиЦє
  135   1          soft_i2c_write_byte((TCS3400_I2C_ADDR << 1) | 1);  // ЖСЕижЗ
  136   1          *val = soft_i2c_read_byte(NACK);    // ЖС + NACK
  137   1          soft_i2c_stop();
  138   1      }
  139          
  140          //ЯШаДФПБъМФДцЦїдйЖСЪ§Он
  141          static int8 tcs3400_read_data(u8 dev_addr, u8 reg_addr, u8 *dat, u16 len)
  142          {
  143   1          u16 i;
  144   1          soft_i2c_start();
  145   1          if (!soft_i2c_write_byte(dev_addr << 1)) // аДЕижЗ
  146   1          {
  147   2              soft_i2c_stop();
  148   2              return -1;
  149   2          }
  150   1          if (!soft_i2c_write_byte(reg_addr)) // аДМФДцЦї
  151   1          {
  152   2              soft_i2c_stop();
  153   2              return -2;
  154   2          }
  155   1          soft_i2c_start();
  156   1          
  157   1          if (!soft_i2c_write_byte((dev_addr << 1) | 0x01)) // ЖСЕижЗ
  158   1          {
  159   2              soft_i2c_stop();
  160   2              return -3;
  161   2          }
  162   1          for (i = 0; i < len; i++) {
  163   2              dat[i] = soft_i2c_read_byte(i < (len - 1)); // зюКѓвЛИіЗЂNACK
  164   2          }
  165   1          soft_i2c_stop();
  166   1          return 0;
  167   1      }


