   65          static float Avg_Filter(float in_data)
   66          {
   67   1          float sum_data = 0.0f;
   68   1          int i = 0;
   69   1          // 前移（左移）滑动窗口
   70   1          for (; i < AVG_NUMS - 1; i++) {
   71   2              dat[i] = dat[i + 1];
   72   2              sum_data += dat[i];
   73   2          }
   74   1          dat[AVG_NUMS - 1] = in_data;
   75   1          sum_data += dat[AVG_NUMS - 1];
   76   1          return (sum_data / AVG_NUMS);
