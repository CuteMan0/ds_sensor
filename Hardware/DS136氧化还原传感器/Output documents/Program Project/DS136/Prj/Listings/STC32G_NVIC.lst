  653          //========================================================================
  654          // 函数: NVIC_CAN_Init
  655          // 描述: CAN嵌套向量中断控制器初始化.
  656          // 参数: Channel:  通道, CAN1/CAN2.
  657          // 参数: State:    中断使能状态, ENABLE/DISABLE.
  658          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  659          // 返回: 执行结果 SUCCESS/FAIL.
  660          // 版本: V1.0, 2023-03-27
  661          //========================================================================
  662          #ifndef CAN1
  663          #define CAN1    0
  664          #endif
  665          #ifndef CAN2
  666          #define CAN2    1
  667          #endif
  668          u8 NVIC_CAN_Init(u8 Channel, u8 State, u8 Priority)
  669          {
  670   1              if(Channel > CAN2) return FAIL;
  671   1              if(Priority > Priority_3) return FAIL;
  672   1              switch(Channel)
  673   1              {
  674   2                      case CAN1:
  675   2                              if(State == ENABLE)
  676   2                                      CANIE = 1;              //bit7 1:Enable Interrupt
  677   2                              else
  678   2                                      CANIE = 0;              //bit7 0:Disable Interrupt
  679   2                              CAN1_Priority(Priority);
  680   2                      break;
  681   2      
  682   2                      case CAN2:
  683   2                              if(State == ENABLE)
  684   2                                      CAN2IE = 1;             //bit7 1:Enable Interrupt
  685   2                              else
  686   2                                      CAN2IE = 0;             //bit7 0:Disable Interrupt
  687   2                              CAN2_Priority(Priority);
  688   2                      break;
  689   2      
  690   2                      default:
  691   2                              return FAIL;
  692   2                      break;
  693   2              }
  694   1              return SUCCESS;
  695   1      }
