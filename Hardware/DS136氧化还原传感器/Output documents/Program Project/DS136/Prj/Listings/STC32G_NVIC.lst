  697          //========================================================================
  698          // 函数: NVIC_LIN_Init
  699          // 描述: LIN嵌套向量中断控制器初始化.
  700          // 参数: State:    中断使能状态, ENABLE/DISABLE.
  701          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  702          // 返回: 执行结果 SUCCESS/FAIL.
  703          // 版本: V1.0, 2020-09-29
  704          //========================================================================
  705          u8 NVIC_LIN_Init(u8 State, u8 Priority)
  706          {
  707   1              if(State <= ENABLE) LIN_Interrupt(State); else  return FAIL;
  708   1              if(Priority <= Priority_3) LIN_Priority(Priority); else  return FAIL;
  709   1              return SUCCESS;
  710   1      }
