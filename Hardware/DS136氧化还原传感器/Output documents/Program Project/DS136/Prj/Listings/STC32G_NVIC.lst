  340          //========================================================================
  341          // 函数: NVIC_DMA_ADC_Init
  342          // 描述: DMA ADC嵌套向量中断控制器初始化.
  343          // 参数: State:    中断使能状态, ENABLE/DISABLE.
  344          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  345          // 参数: Bus_Priority: 数据总线访问优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  346          // 返回: 执行结果 SUCCESS/FAIL.
  347          // 版本: V1.0, 2021-05-21
  348          //========================================================================
  349          u8 NVIC_DMA_ADC_Init(u8 State, u8 Priority, u8 Bus_Priority)
  350          {
  351   1              DMA_ADC_CFG &= ~0x0f;
  352   1              if(Priority <= Priority_3) DMA_ADC_CFG |= Priority << 2;
  353   1              if(Bus_Priority <= Priority_3) DMA_ADC_CFG |= Bus_Priority;     //数据总线访问优先级
  354   1              if(State == ENABLE)
  355   1                      DMA_ADC_CFG |= 0x80;            //bit7 1:Enable Interrupt
  356   1              else
  357   1                      DMA_ADC_CFG &= ~0x80;           //bit7 0:Disable Interrupt
  358   1              return SUCCESS;
  359   1      }
