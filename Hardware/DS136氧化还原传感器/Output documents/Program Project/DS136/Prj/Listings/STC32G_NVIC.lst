  168          //========================================================================
  169          // 函数: NVIC_CMP_Init
  170          // 描述: 比较器嵌套向量中断控制器初始化.
  171          // 参数: State:    中断使能状态, RISING_EDGE/FALLING_EDGE/DISABLE.
  172          // 参数: Priority: 中断优先级, Priority_0,Priority_1,Priority_2,Priority_3.
  173          // 返回: 执行结果 SUCCESS/FAIL.
  174          // 版本: V1.0, 2020-09-29
  175          //========================================================================
  176          u8 NVIC_CMP_Init(u8 State, u8 Priority)
  177          {
  178   1              if(State & RISING_EDGE) PIE = 1;                        //允许上升沿中断
  179   1              else    PIE = 0;                        //禁止上升沿中断
  180   1              if(State & FALLING_EDGE)        NIE = 1;                //允许下降沿中断
  181   1              else    NIE = 0;                        //禁止上升沿中断
  182   1              if(Priority <= Priority_3) CMP_Priority(Priority); else  return FAIL;
  183   1              return SUCCESS;
  184   1      }
