    7          //========================================================================
    8          // 函数: u8     Timer_Inilize(u8 TIM, TIM_InitTypeDef *TIMx)
    9          // 描述: 定时器初始化程序.
   10          // 参数: TIMx: 结构参数,请参考timer.h里的定义.
   11          // 返回: 成功返回 SUCCESS, 错误返回 FAIL.
   12          // 版本: V1.0, 2012-10-22
   13          //========================================================================
   14          u8      Timer_Inilize(u8 TIM, TIM_InitTypeDef *TIMx)
   15          {
   16   1              if(TIM == Timer0)
   17   1              {
   18   2                      Timer0_Stop();          //停止计数
   19   2                      if(TIMx->TIM_Mode > TIM_16BitAutoReloadNoMask)  return FAIL;    //错误
   20   2                      TMOD = (TMOD & ~0x03) | TIMx->TIM_Mode; //工作模式,0: 16位自动重装, 1: 16位定时/计数, 2: 8位自动重装, 3
             -: 不可屏蔽16位自动重装
   21   2                      if(TIMx->TIM_ClkSource > TIM_CLOCK_Ext) return FAIL;
   22   2                      Timer0_CLK_Select(TIMx->TIM_ClkSource); //对外计数或分频, 定时12T/1T
   23   2                      Timer0_CLK_Output(TIMx->TIM_ClkOut);            //输出时钟使能
   24   2                      T0_Load(TIMx->TIM_Value);
   25   2              TM0PS = TIMx->TIM_PS;
   26   2                      Timer0_Run(TIMx->TIM_Run);
   27   2                      return  SUCCESS;                //成功
   28   2              }
   29   1      
   30   1              if(TIM == Timer1)
   31   1              {
   32   2                      Timer1_Stop();          //停止计数
   33   2                      if(TIMx->TIM_Mode > TIM_16BitAutoReloadNoMask)  return FAIL;    //错误
   34   2                      TMOD = (TMOD & ~0x30) | (TIMx->TIM_Mode << 4);  //工作模式,0: 16位自动重装, 1: 16位定时/计数, 2: 8位自动
             -重装, 3: 停止工作
   35   2                      if(TIMx->TIM_ClkSource > TIM_CLOCK_Ext) return FAIL;
   36   2                      Timer1_CLK_Select(TIMx->TIM_ClkSource); //对外计数或分频, 定时12T/1T
   37   2                      Timer1_CLK_Output(TIMx->TIM_ClkOut);            //输出时钟使能
   38   2                      T1_Load(TIMx->TIM_Value);
   39   2              TM1PS = TIMx->TIM_PS;
   40   2                      Timer1_Run(TIMx->TIM_Run);
   41   2                      return  SUCCESS;                //成功
   42   2              }
   43   1      
   44   1              if(TIM == Timer2)               //Timer2,固定为16位自动重装, 中断无优先级
   45   1              {
   46   2                      Timer2_Stop();  //停止计数
   47   2                      Timer2_CLK_Select(TIMx->TIM_ClkSource); //对外计数或分频, 定时12T/1T
   48   2                      Timer2_CLK_Output(TIMx->TIM_ClkOut);            //输出时钟使能
