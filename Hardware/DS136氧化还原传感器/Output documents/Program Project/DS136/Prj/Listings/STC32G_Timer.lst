   50   2                      T2_Load(TIMx->TIM_Value);
   51   2              TM2PS = TIMx->TIM_PS;
   52   2                      Timer2_Run(TIMx->TIM_Run);
   53   2                      return  SUCCESS;                //成功
   54   2              }
   55   1      
