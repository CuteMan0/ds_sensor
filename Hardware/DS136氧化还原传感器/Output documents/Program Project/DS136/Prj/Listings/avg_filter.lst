   13          
   14          void avg_filter_init(avg_filter_t *filter, avgf_data_t *buffer, u16 len)
   15          {
   16   1          u16 i;
   17   1      
   18   1          if (!filter || !buffer || 0 == len)
   19   1              return;
   20   1      
   21   1          filter->buffer = buffer;
   22   1          filter->len = len;
   23   1          filter->index = 0;
   24   1          filter->sum = 0;
   25   1          filter->valid_count = 0;
   26   1      
   27   1          for (i = 0; i < len; i++)
   28   1              buffer[i] = 0;
   29   1      }
   30          
   31          avgf_out_t avg_filter_update(avg_filter_t *filter, avgf_data_t new_sample)
   32          {
   33   1          if (!filter || !filter->buffer || 0 == filter->len)
   34   1              return 0;
   35   1      
   36   1          filter->sum -= filter->buffer[filter->index];
   37   1          filter->buffer[filter->index] = new_sample;
   38   1          filter->sum += new_sample;
   39   1      
   40   1          filter->index = (filter->index + 1) % filter->len;
   41   1      
   42   1          if (filter->valid_count < filter->len)
   43   1              filter->valid_count++;
   44   1      
   45   1          return (filter->sum / filter->valid_count);
   46   1      }


