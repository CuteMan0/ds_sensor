   12          #include "lowpass_filter.h"
   13          
   14          void lowpass_filter_init(lp_filter_t *f, lp_data_t init_value, lp_calc_t alpha)
   15          {
   16   1          if(!f)
   17   1              return;
   18   1      
   19   1          f->last   = (lp_calc_t)init_value;
   20   1          f->alpha  = alpha;
   21   1          f->init_ok = 1;
   22   1      }
   23          
   24          lp_data_t lowpass_filter_update(lp_filter_t *f, lp_data_t new_sample)
   25          {
   26   1          lp_calc_t out;
   27   1      
   28   1          if(!f)
   29   1              return 0;
   30   1      
   31   1          if(!f->init_ok)
   32   1          {
   33   2              // 뒤寧늴頓契菱땡놓迦뺏
   34   2              f->last    = (lp_calc_t)new_sample;
   35   2              f->init_ok = 1;
   36   2          }
   37   1      
   38   1          out = f->last + f->alpha * ((lp_calc_t)new_sample - f->last);
   39   1          f->last = out;
   40   1      
   41   1          return (lp_data_t)out;
   42   1      }


