   59          #define AVG_NUMS 20
   60          volatile float dat[AVG_NUMS] = {0.0f};
   61          static float Avg_Filter(float in_data)
   62          {
   63   1          float sum_data = 0.0f;
   64   1          int i = 0;
   65   1          // 前移（左移）滑动窗口
   66   1          for (; i < AVG_NUMS - 1; i++) {
   67   2              dat[i] = dat[i + 1];
   68   2              sum_data += dat[i];
   69   2          }
   70   1          dat[AVG_NUMS - 1] = in_data;
   71   1          sum_data += dat[AVG_NUMS - 1];
   72   1          return (sum_data / AVG_NUMS);
   73   1      }


