   60   2          if (I2CSLST & 0x02)
   61   2          {
   62   3            I2CTXD = 0xff;
   63   3          }
   64   2          else
   65   2          {
   66   3            I2CTXD = I2C_Buffer[++I2CIsr.addr];
   67   3          }
   68   2        }
