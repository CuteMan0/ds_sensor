   22          void I2C_ISR_Handler() interrupt I2C_VECTOR
   23          {
   24   1        // TODO: 在此处添加用户代码
   25   1      
   26   1        // 主机模式
   27   1        I2CMSST &= ~0x40;       //I2C指令发送完成状态清除
   28   1      
   29   1        if(DMA_I2C_CR & 0x04)   //ACKERR
   30   1        {
   31   2          DMA_I2C_CR &= ~0x04;  //发数据后收到NAK
   32   2        }
   33   1      
   34   1        // 从机模式
   35   1        if (I2CSLST & 0x40)
   36   1        {
   37   2          I2CSLST &= ~0x40;                       //处理START事件
   38   2        }
   39   1        else if (I2CSLST & 0x20)
   40   1        {
   41   2          I2CSLST &= ~0x20;                       //处理RECV事件，SLACKO设置为0
   42   2          if (I2CIsr.isda)
   43   2          {
   44   3            I2CIsr.isda = 0;                    //处理RECV事件（RECV DEVICE ADDR）
   45   3          }
   46   2          else if (I2CIsr.isma)
   47   2          {
   48   3            I2CIsr.isma = 0;                    //处理RECV事件（RECV MEMORY ADDR）
   49   3            I2CIsr.addr = I2CRXD;
   50   3            I2CTXD = I2C_Buffer[I2CIsr.addr];
   51   3          }
   52   2          else
   53   2          {
   54   3            I2C_Buffer[I2CIsr.addr++] = I2CRXD; //处理RECV事件（RECV DATA）
   55   3          }
   56   2        }
   57   1        else if (I2CSLST & 0x10)
   58   1        {
C251 COMPILER V5.60.0,  STC32G_I2C_Isr                                                     08/05/25  18:16:59  PAGE 2   

