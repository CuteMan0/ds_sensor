stmt  level    source

    1          #include "DS139_O2_drive.h"
    2          
    3          #include "STC32G_ADC.h"
    4          #include "STC32G_GPIO.h"
    5          #include "STC32G_Delay.h"
    6          
    7          #include "avg_filter.h"
    8          
    9          #define V_REF 3.3f
   10          #define A0 15               // 短接传感器的ADC，用于消除电路噪声干扰
   11          #define A1 566              // 空气中的ADC，用于基准
   12          avg_filter_t O2_filter;    //滤波器
   13          u16          O2_buffer[12];//滤波数组
   14          
   15          void O2_Init(void)
   16          {
   17   1          ADC_InitTypeDef ADC_InitSruct;
   18   1          
   19   1          P1_MODE_IN_HIZ(GPIO_Pin_0);         //P1.0设置为高阻输入
   20   1          
   21   1          ADC_InitSruct.ADC_SMPduty = 31;
   22   1          ADC_InitSruct.ADC_Speed = ADC_SPEED_2X16T;
   23   1          ADC_InitSruct.ADC_AdjResult = ADC_LEFT_JUSTIFIED;
   24   1          ADC_InitSruct.ADC_CsSetup = 0;
   25   1          ADC_InitSruct.ADC_CsHold = 1;
   26   1          
   27   1          ADC_Inilize(&ADC_InitSruct);
   28   1          ADC_PowerControl(ENABLE);
   29   1          
   30   1          AvgFilter_Init(&O2_filter,O2_buffer,sizeof(O2_buffer)/2);
   31   1      }
   32          
   33          float O2_Read(void)
   34          {
   35   1          u16 adc_val = 0;
   36   1          float o2_val = 0.0f;
   37   1          
   38   1          adc_val = Get_ADCResult(ADC_CH0);
   39   1          adc_val = AvgFilter_Update(&O2_filter,adc_val);
   40   1          o2_val = (float)(adc_val - A0) / (float)(A1 - A0);
   41   1          o2_val *= 20.90f;
   42   1          
   43   1          o2_val = (o2_val > 0.0f) ? o2_val : 0.0f;
   44   1          o2_val = (o2_val < 100.0f) ? o2_val : 100.0f;
   45   1          
   46   1          return o2_val;
   47   1      }


