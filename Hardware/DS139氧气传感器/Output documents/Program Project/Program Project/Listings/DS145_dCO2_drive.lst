   54          u16 middleFilter(u16 in_data)
   55          {
   56   1          u32 sum = 0;
   57   1          u16 temp[MIDDLE_NUMS];
   58   1          u16 change;
C251 COMPILER V5.60.0,  DS145_dCO2_drive                                                   22/07/25  10:42:00  PAGE 2   

   59   1          u8 i,j;
   60   1          //记录数据
   61   1          for(i=0; i<MIDDLE_NUMS - 1; i++)
   62   1          {
   63   2              array[i]=array[i+1];
   64   2          }
   65   1          array[MIDDLE_NUMS - 1] = in_data;
   66   1          //复制数据
   67   1          for(i=0; i<MIDDLE_NUMS; i++)
   68   1              temp[i] = array[i];
   69   1          //冒泡法排序
   70   1          for(i=1; i<MIDDLE_NUMS; i++)
   71   1              for(j=0; j<MIDDLE_NUMS-i; j++)
   72   1              {
   73   2                  if(temp[j] > temp[j+1])
   74   2                  {
   75   3                      change = temp[j];
   76   3                      temp[j] = temp[j+1];
   77   3                      temp[j+1] = change;
   78   3                  }
   79   2              }
   80   1          //求和
   81   1          for(i=(MIDDLE_NUMS*2)/5; i<(MIDDLE_NUMS*3)/5; i++)
   82   1              sum = sum + temp[i];
   83   1          //返回平均值
   84   1          return(sum/((MIDDLE_NUMS*2)/3-MIDDLE_NUMS/3));
   85   1      }


