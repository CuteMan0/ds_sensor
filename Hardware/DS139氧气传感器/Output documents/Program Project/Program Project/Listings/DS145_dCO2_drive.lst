   32   1          AvgFilter_Init(&dCO2_filter,dCO2_buffer,sizeof(dCO2_buffer)/2);
   33   1          delay_ms(5000);//开机设备预热
   34   1      }
   35          
   36          float dCO2_Read(void)
   37          {
   38   1          u16 adc_val = 0;
   39   1          float adc_vol = 0.0f;
   40   1          float dco2_val = 0.0f;
   41   1          
   42   1          adc_val = Get_ADCResult(ADC_CH0);
   43   1          adc_val = AvgFilter_Update(&dCO2_filter,adc_val);
   44   1          adc_val = middleFilter(adc_val);
   45   1          adc_vol = (float)adc_val * V_REF / 4096.0f;
   46   1          
   47   1          dco2_val = 3846 * (adc_vol - 0.4f);
   48   1          
   49   1          return (dco2_val > 0.0f) ? dco2_val : 0.0f ;
   50   1      }
