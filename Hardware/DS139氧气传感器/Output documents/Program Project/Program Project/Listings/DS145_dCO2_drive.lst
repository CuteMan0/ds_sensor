    9          #define V_REF 3.3f
   10          #define MIDDLE_NUMS 24
   11          avg_filter_t dCO2_filter;    //滤波器
   12          u16          dCO2_buffer[24];//滤波数组
   13          u16          array[MIDDLE_NUMS];      //中值滤波数组
   14          
   15          u16 middleFilter(u16 in_data);
   16          
   17          void dCO2_Init(void)
   18          {
   19   1          ADC_InitTypeDef ADC_InitSruct;
   20   1          
   21   1          P1_MODE_IN_HIZ(GPIO_Pin_0);         //P1.0设置为高阻输入
   22   1          
   23   1          ADC_InitSruct.ADC_SMPduty = 31;
   24   1          ADC_InitSruct.ADC_Speed = ADC_SPEED_2X16T;
   25   1          ADC_InitSruct.ADC_AdjResult = ADC_LEFT_JUSTIFIED;
   26   1          ADC_InitSruct.ADC_CsSetup = 0;
   27   1          ADC_InitSruct.ADC_CsHold = 1;
   28   1          
   29   1          ADC_Inilize(&ADC_InitSruct);
   30   1          ADC_PowerControl(ENABLE);
