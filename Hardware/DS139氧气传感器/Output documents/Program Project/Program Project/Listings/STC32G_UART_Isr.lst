   13          #ifdef UART1
   14          void UART1_ISR_Handler (void) interrupt UART1_VECTOR
   15          {
   16   1        u8 Status;
   17   1      
   18   1        if(RI)
   19   1        {
   20   2          RI = 0;
   21   2      
   22   2          //--------USART LIN---------------
   23   2          Status = USARTCR5;
   24   2          if(Status & 0x02)     //if LIN header is detected
   25   2          {
   26   3            B_ULinRX1_Flag = 1;
   27   3          }
   28   2      
   29   2          if(Status & 0xc0)     //if LIN break is detected / LIN header error is detected
   30   2          {
   31   3            COM1.RX_Cnt = 0;
   32   3          }
   33   2          USARTCR5 &= ~0xcb;    //Clear flag
   34   2          //--------------------------------
   35   2          
   36   2              if(COM1.RX_Cnt >= COM_RX1_Lenth)  COM1.RX_Cnt = 0;
   37   2              RX1_Buffer[COM1.RX_Cnt++] = SBUF;
   38   2              COM1.RX_TimeOut = TimeOutSet1;
   39   2        }
   40   1      
   41   1        if(TI)
   42   1        {
   43   2          TI = 0;
   44   2          
   45   2              #if(UART_QUEUE_MODE == 1)   //털뙤角뤠賈痰뚠죗친駕
                   if(COM1.TX_send != COM1.TX_write)
                   {
                     SBUF = TX1_Buffer[COM1.TX_send];
                     if(++COM1.TX_send >= COM_TX1_Lenth)   COM1.TX_send = 0;
                   }
                   else  COM1.B_TX_busy = 0;
                       #else
   53   2              COM1.B_TX_busy = 0;     //賈痰羸힘렘駕랙箇殮쌈헌뇜런챈깃羚
   54   2              #endif
   55   2        }
   56   1      }
   57          #endif
