  209          #define AVG_NUMS 10
  210          volatile float dat[AVG_NUMS] = {0.0f};
  211          static float Avg_Filter(float in_data)
  212          {
  213   1          float sum_data = 0.0f;
  214   1          int i = 0;
  215   1          // 前移（左移）滑动窗口
  216   1          for (; i < AVG_NUMS - 1; i++) {
  217   2              dat[i] = dat[i + 1];
  218   2              sum_data += dat[i];
  219   2          }
  220   1          dat[AVG_NUMS - 1] = in_data;
  221   1          sum_data += dat[AVG_NUMS - 1];
  222   1          return (sum_data / AVG_NUMS);
