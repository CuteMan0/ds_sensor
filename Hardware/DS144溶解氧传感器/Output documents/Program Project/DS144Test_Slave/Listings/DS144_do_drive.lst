   59          volatile float dat[AVG_NUMS] = {0.0f};
   60          static float Avg_Filter(float in_data)
   61          {
   62   1          float sum_data = 0.0f;
   63   1          int i = 0;
   64   1          // 前移（左移）滑动窗口
   65   1          for (; i < AVG_NUMS - 1; i++) {
   66   2              dat[i] = dat[i + 1];
   67   2              sum_data += dat[i];
   68   2          }
   69   1          dat[AVG_NUMS - 1] = in_data;
   70   1          sum_data += dat[AVG_NUMS - 1];
   71   1          return (sum_data / AVG_NUMS);
